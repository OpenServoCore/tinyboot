{
  "languages": {
    "Rust": {
      "format_on_save": "on"
    },
    "Markdown": {
      "soft_wrap": "none"
    }
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "linkedProjects": [
          "lib/Cargo.toml",
          "ch32/Cargo.toml",
          "examples/ch32/v003/Cargo.toml"
        ],
        "cargo": {
          "target": "riscv32imc-unknown-none-elf"
        },
        "check": {
          "command": "clippy",
          "allTargets": false
        }
      }
    }
  }
}
