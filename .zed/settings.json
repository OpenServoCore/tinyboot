{
  "languages": {
    "Rust": {
      "format_on_save": "on",
    },
  },
  "lsp": {
    "rust-analyzer": {
      "initialization_options": {
        "cargo": {
          "target": "riscv32imac-unknown-none-elf",
          "features": ["ch32v103c8u6", "system-flash"],
        },
        "check": {
          "command": "clippy",
          "allTargets": false,
        },
      },
    },
  },
}
