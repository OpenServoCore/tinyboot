#!/bin/sh
set -e

# --- Core libraries (host target) ---
(cd lib && cargo fmt --all --check)
(cd lib && cargo clippy -p tinyboot-core -p tinyboot-protocol --all-targets -- -D warnings)
(cd lib && cargo test -p tinyboot-core -p tinyboot-protocol)

# --- CH32 libraries (embedded target, needs nightly + build-std) ---
TARGET_JSON=../examples/ch32/v003/riscv32ec-unknown-none-elf.json
CHIP=ch32v003f4p6
(cd ch32 && cargo +nightly clippy -p tinyboot-ch32-hal -p tinyboot-ch32-boot -p tinyboot-ch32-app \
  --no-default-features --features $CHIP \
  --target $TARGET_JSON \
  -Zbuild-std=core -Zjson-target-spec \
  -- -D warnings)

# --- Examples ---
for flash in system-flash user-flash; do
  (cd examples/ch32/v003 && cargo +nightly clippy -p boot --no-default-features --features "ch32v003f4p6,$flash" -- -D warnings)
  (cd examples/ch32/v003 && cargo +nightly clippy -p app --no-default-features --features "ch32v003f4p6,$flash" -- -D warnings)
done
